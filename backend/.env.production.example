# Production environment for the FastAPI backend on Render.
# Copy ONLY the variable names into Render's "Environment" dashboard, not this file.
# (Render stores secrets — don't commit the real values.)

# ─── Admin auth (set these in Render's Environment) ───────────────
# Generate the hash by running locally:
#   cd backend && .venv/bin/python -m app.tools.hashpw 'your-real-password'
ADMIN_USERNAME=gokul
ADMIN_PASSWORD_HASH=<paste-bcrypt-hash-here>

# Generate a long random string:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=<paste-long-random-string-here>

# ─── Frontend origin(s) ──────────────────────────────────────────
# Comma-separated allowed origins for CORS. Include the Cloudflare Pages
# preview-deploy domain too (the *.pages.dev address).
# Example:
#   FRONTEND_ORIGIN=https://gokulraam.dev,https://gokulraam-dev.pages.dev
FRONTEND_ORIGIN=https://gokulraam-dev.pages.dev

# ─── Database — Neon Postgres ────────────────────────────────────
# From your Neon dashboard → Connection details → "Pooled connection"
# Must include `?sslmode=require`.
DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Cloudflare R2 — file uploads ────────────────────────────────
# Cloudflare dashboard → R2 → your bucket → "Manage API Tokens" gives you
# the access key + secret. The endpoint is region "auto".
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET=gokulraam-uploads
# Either the "public bucket URL" from Cloudflare's R2 settings (pub-xxxx.r2.dev)
# or a custom domain you point at the bucket. Must NOT end with a slash.
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
