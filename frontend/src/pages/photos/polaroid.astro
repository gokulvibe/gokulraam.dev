---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import EditableField from '@/components/admin/EditableField';

const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8000';

interface PhotoRow {
  id: number;
  slug: string;
  url: string;
  caption: string;
  taken_at: string;
  order: number;
}

let photos: PhotoRow[] = [];
let backendOk = true;
try {
  const res = await fetch(`${API_BASE}/api/photos`);
  if (res.ok) photos = await res.json();
  else backendOk = false;
} catch {
  backendOk = false;
}

// Deterministic small rotations + offsets per polaroid index so the page
// renders the same each visit but still feels hand-pinned.
const TRANSFORMS = [
  { rot: -4.5, x:  4, y:  0 },
  { rot:  3.5, x: -3, y:  6 },
  { rot: -2.0, x:  6, y: -2 },
  { rot:  5.0, x: -5, y:  4 },
  { rot: -3.2, x:  2, y: -3 },
  { rot:  2.8, x: -2, y:  5 },
  { rot: -5.5, x:  5, y:  1 },
  { rot:  4.2, x: -4, y: -1 },
];
---

<Base title="Photos · Polaroid — Gokul Raam" description="A polaroid contact sheet.">
  <header class="mb-10">
    <div class="label mb-4">// photos · polaroid sheet</div>
    <h1 class="display text-5xl md:text-6xl">
      A polaroid<br /><span class="italic text-ember">contact sheet.</span>
    </h1>
    <p class="mt-6 max-w-xl text-mist">
      Same photos, scattered like a darkroom drying line. Pick one up — they
      enlarge into a lightbox. Hover for a slight pickup of the corner.
    </p>
    <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.16em] text-ghost">
      view:
      <a href="/photos" class="hover:text-cream">← camera roll</a>
      <span class="mx-2 text-rule">·</span>
      <span class="text-cream">polaroid contact sheet</span>
    </p>
  </header>

  {!backendOk && (
    <div class="card border-rose/30 bg-rose/5 mb-8">
      <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-rose mb-2">// backend offline</p>
      <p class="text-sm text-parchment">The API at <code class="font-mono">{API_BASE}</code> is unreachable.</p>
    </div>
  )}

  <section class="polaroid-board" aria-label="Polaroid contact sheet">
    {photos.map((p, idx) => {
      const t = TRANSFORMS[idx % TRANSFORMS.length];
      return (
        <figure
          class="polaroid"
          data-idx={idx}
          data-url={p.url}
          data-caption={p.caption}
          data-taken={p.taken_at}
          style={`--rot:${t.rot}deg;--tx:${t.x}px;--ty:${t.y}px;`}
        >
          <div class="polaroid__pane">
            {p.url ? (
              <img src={p.url} alt={p.caption || `polaroid ${idx + 1}`} loading="lazy" />
            ) : (
              <div class="polaroid__empty">no image</div>
            )}
          </div>
          <figcaption class="polaroid__cap">
            <span class="polaroid__text">
              <EditableField
                client:load
                endpoint={`/api/photos/${p.id}`}
                field="caption"
                initial={p.caption}
                placeholder="caption"
              />
            </span>
            <span class="polaroid__date">
              <EditableField
                client:load
                endpoint={`/api/photos/${p.id}`}
                field="taken_at"
                initial={p.taken_at}
                placeholder="when"
              />
            </span>
          </figcaption>
          <div class="polaroid__urledit">
            <EditableField
              client:load
              endpoint={`/api/photos/${p.id}`}
              field="url"
              initial={p.url}
              placeholder="image url"
              adminOnly
            />
          </div>
          <span class="polaroid__pin" aria-hidden></span>
        </figure>
      );
    })}
  </section>
</Base>

<style>
  .polaroid-board {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 36px 20px;
    padding: 30px 4px;
    background:
      radial-gradient(circle at 20% 20%, rgba(213, 178, 117, 0.04) 0%, transparent 50%),
      radial-gradient(circle at 80% 60%, rgba(213, 178, 117, 0.03) 0%, transparent 45%),
      #0a0a0e;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    position: relative;
  }
  @media (min-width: 720px) {
    .polaroid-board { grid-template-columns: repeat(3, 1fr); gap: 50px 24px; padding: 50px 30px; }
  }
  @media (min-width: 1080px) {
    .polaroid-board { grid-template-columns: repeat(4, 1fr); }
  }

  .polaroid {
    background: #f6f0e2;
    padding: 12px 12px 48px;
    border-radius: 1.5px;
    position: relative;
    transform: rotate(var(--rot)) translate(var(--tx), var(--ty));
    transition: transform 0.32s cubic-bezier(0.4, 1.2, 0.4, 1), box-shadow 0.3s, z-index 0s 0.3s;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 14px 24px rgba(0, 0, 0, 0.55),
      0 4px 6px rgba(0, 0, 0, 0.35);
    color: #1c1a14;
    margin: 0;
    cursor: zoom-in;
    z-index: 1;
  }
  .polaroid:hover {
    transform: rotate(0deg) translate(0, -8px) scale(1.04);
    z-index: 10;
    transition: transform 0.32s cubic-bezier(0.4, 1.2, 0.4, 1), box-shadow 0.3s, z-index 0s;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.7) inset,
      0 26px 40px rgba(0, 0, 0, 0.65),
      0 6px 10px rgba(0, 0, 0, 0.4);
  }

  .polaroid__pane {
    aspect-ratio: 1 / 1;
    background: #16140e;
    overflow: hidden;
    position: relative;
  }
  .polaroid__pane img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.02);
    display: block;
  }
  .polaroid__empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .polaroid__cap {
    margin-top: 14px;
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    line-height: 1.3;
    color: #2a2419;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .polaroid__date {
    font-size: 10px;
    font-style: normal;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(42, 36, 25, 0.55);
    font-family: var(--font-mono, ui-monospace, monospace);
  }

  /* Faux pin on top of each polaroid */
  .polaroid__pin {
    position: absolute;
    top: -7px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #d5b275, #8a6d3f 70%);
    box-shadow: 0 2px 3px rgba(0, 0, 0, 0.4);
  }

  /* Admin URL editor — small strip floats over photo top */
  .polaroid__urledit {
    position: absolute;
    top: 18px;
    left: 18px;
    right: 18px;
    padding: 4px 6px;
    background: rgba(20, 18, 12, 0.9);
    color: #f5efe3;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 10px;
    border-radius: 2px;
  }
  .polaroid__urledit:empty { display: none; }

  /* Make captions in the polaroid use dark text even when site is in light theme */
  :global([data-theme='light']) .polaroid { background: #fbf6ea; }
  :global([data-theme='light']) .polaroid-board {
    background:
      radial-gradient(circle at 20% 20%, rgba(213, 178, 117, 0.08) 0%, transparent 50%),
      #f1ecde;
    border-color: rgba(0, 0, 0, 0.08);
  }
</style>

<script is:inline>
  (() => {
    const polaroids = Array.from(document.querySelectorAll('.polaroid'));
    if (!polaroids.length) return;

    // Reuse the same Lightbox markup pattern as /photos
    const lb = document.createElement('div');
    lb.className = 'lightbox';
    lb.innerHTML = `
      <button class="lightbox__close" type="button" aria-label="Close">esc · close</button>
      <button class="lightbox__nav lightbox__nav--prev" type="button" aria-label="Previous">‹</button>
      <button class="lightbox__nav lightbox__nav--next" type="button" aria-label="Next">›</button>
      <img alt="" />
      <div class="lightbox__cap">
        <span class="lightbox__no"></span>
        <span class="lightbox__text"></span>
        <span class="lightbox__date"></span>
      </div>
    `;
    document.body.appendChild(lb);
    const lbImg = lb.querySelector('img');
    const lbNo = lb.querySelector('.lightbox__no');
    const lbText = lb.querySelector('.lightbox__text');
    const lbDate = lb.querySelector('.lightbox__date');
    let cur = 0;

    function openAt(i) {
      const f = polaroids[i];
      const url = f?.getAttribute('data-url');
      if (!url) return;
      cur = i;
      lbImg.src = url;
      lbImg.alt = f.getAttribute('data-caption') || '';
      lbNo.textContent = String(i + 1).padStart(2, '0');
      lbText.textContent = f.getAttribute('data-caption') || '';
      lbDate.textContent = f.getAttribute('data-taken') || '';
      lb.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb.classList.remove('is-open');
      document.body.style.overflow = '';
    }
    function next() { openAt((cur + 1) % polaroids.length); }
    function prev() { openAt((cur - 1 + polaroids.length) % polaroids.length); }

    polaroids.forEach((f, i) => {
      f.addEventListener('click', (e) => {
        if (e.target.closest('.editable-input') || e.target.closest('.editable')) return;
        if (e.target.closest('.polaroid__urledit')) return;
        openAt(i);
      });
    });
    lb.querySelector('.lightbox__close').addEventListener('click', close);
    lb.querySelector('.lightbox__nav--next').addEventListener('click', next);
    lb.querySelector('.lightbox__nav--prev').addEventListener('click', prev);
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowRight') next();
      if (e.key === 'ArrowLeft') prev();
    });
  })();
</script>
