---
// SSR so admin edits show on refresh.
export const prerender = false;

import Base from '@/layouts/Base.astro';
import Card from '@/components/Card.astro';
import EditableUsesField from '@/components/admin/EditableUsesField';

const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8000';

interface UsesItemApi {
  id: number;
  category: string;
  slug: string;
  name: string;
  note: string;
  order: number;
}

// Static section chrome — flavor copy, glyphs, colors. Items come from DB.
interface SectionChrome {
  title: string;
  blurb: string;
  bar: 'gold' | 'ember' | 'sage' | 'rose' | 'lilac';
  glyph: string;
}
const SECTIONS: Record<string, SectionChrome> = {
  code:     { title: 'code',     blurb: 'where the lines get written', bar: 'ember', glyph: '⌘' },
  runtime:  { title: 'runtime',  blurb: 'the stack i reach for',       bar: 'ember', glyph: '⚙' },
  hardware: { title: 'hardware', blurb: 'the metal',                    bar: 'gold',  glyph: '◈' },
  sound:    { title: 'sound',    blurb: 'focus mode',                   bar: 'lilac', glyph: '◐' },
  court:    { title: 'court',    blurb: 'on-court kit',                 bar: 'rose',  glyph: '✺' },
  fitness:  { title: 'fitness',  blurb: 'off-court kit',                bar: 'sage',  glyph: '✦' },
  daily:    { title: 'daily',    blurb: 'the small things',             bar: 'gold',  glyph: '◇' },
};
const SECTION_ORDER = ['code', 'runtime', 'hardware', 'sound', 'court', 'fitness', 'daily'];

const barColor: Record<SectionChrome['bar'], string> = {
  gold: '#c9a96e',
  ember: '#ea580c',
  sage: '#5a8a7a',
  rose: '#b9472f',
  lilac: '#9d88b8',
};

// Fetch items, group by category
let items: UsesItemApi[] = [];
let backendOk = true;
try {
  const res = await fetch(`${API_BASE}/api/uses`);
  if (res.ok) items = await res.json();
  else backendOk = false;
} catch {
  backendOk = false;
}

const grouped = new Map<string, UsesItemApi[]>();
for (const it of items) {
  if (!grouped.has(it.category)) grouped.set(it.category, []);
  grouped.get(it.category)!.push(it);
}
---

<Base title="Uses — Gokul Raam" description="Things I use daily — code, kit, court, life.">
  <header class="mb-12">
    <div class="label mb-4">// uses</div>
    <h1 class="display text-5xl md:text-6xl">
      Things I<br /><span class="italic text-ember">use daily.</span>
    </h1>
    <p class="mt-6 max-w-xl text-mist">
      Code stack, hardware, on-court kit, and the rest of the everyday inventory.
      Inspired by <a href="https://uses.tech" class="text-cream underline-offset-4 hover:underline">uses.tech</a>.
      Placeholders (—) are spots to fill in.
    </p>
  </header>

  {!backendOk && (
    <div class="card border-rose/30 bg-rose/5 mb-8">
      <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-rose mb-2">// backend offline</p>
      <p class="text-sm text-parchment">The API at <code class="font-mono">{API_BASE}</code> is unreachable.</p>
    </div>
  )}

  <div class="grid gap-4 md:grid-cols-2">
    {SECTION_ORDER.map((catKey) => {
      const chrome = SECTIONS[catKey];
      const rows = grouped.get(catKey) ?? [];
      if (!chrome) return null;
      return (
        <Card class="!p-6" style={`--card-bar: ${barColor[chrome.bar]};`}>
          <header class="mb-5 flex items-baseline justify-between">
            <div class="flex items-center gap-2.5">
              <span
                class="inline-block h-3.5 w-0.5 rounded-sm"
                style={`background: ${barColor[chrome.bar]}; box-shadow: 0 0 6px ${barColor[chrome.bar]}40;`}
              ></span>
              <h2 class="font-mono text-[12.5px] uppercase tracking-[0.22em] text-cream">{chrome.title}</h2>
            </div>
            <span class="font-display italic text-lg" style={`color: ${barColor[chrome.bar]}; opacity: 0.55;`}>
              {chrome.glyph}
            </span>
          </header>
          <p class="mb-4 -mt-2 font-display italic text-[14px] text-parchment opacity-75">
            {chrome.blurb}
          </p>
          <ul class="divide-y divide-rule">
            {rows.map((it) => (
              <li class="flex items-baseline justify-between gap-4 py-2.5">
                <span class="font-display text-[16px] leading-tight">
                  <EditableUsesField
                    client:load
                    itemId={it.id}
                    field="name"
                    initial={it.name}
                    className="font-display"
                    placeholder="item name"
                  />
                </span>
                <span class="font-mono text-[10.5px] uppercase tracking-[0.14em] text-mist text-right shrink-0 min-w-[40%]">
                  <EditableUsesField
                    client:load
                    itemId={it.id}
                    field="note"
                    initial={it.note}
                    className="font-mono"
                    placeholder="short note"
                  />
                </span>
              </li>
            ))}
          </ul>
        </Card>
      );
    })}
  </div>

  <p class="mt-12 font-mono text-[11px] uppercase tracking-[0.16em] text-ghost">
    // sign in as admin to edit any field inline
  </p>
</Base>
