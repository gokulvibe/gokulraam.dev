---
// SSR: fetch live from the API on every request so inline edits and newly-created
// posts are visible immediately. No build-time path enumeration; any slug that
// exists in the DB resolves here.
export const prerender = false;

import Base from '@/layouts/Base.astro';
import EditableTitle from '@/components/admin/EditableTitle';
import EditableTags from '@/components/admin/EditableTags';
import EditableBody from '@/components/admin/EditableBody';
import TilShare from '@/components/TilShare';
import EditableAttachments from '@/components/admin/EditableAttachments';
import PostStatusActions from '@/components/admin/PostStatusActions';
import TilDraftLoader from '@/components/admin/TilDraftLoader';
import BackendWarming from '@/components/BackendWarming';

const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8000';

interface Attachment {
  id: number;
  filename: string;
  mime_type: string;
  size_bytes: number;
  stored_path: string;
}

interface TilPost {
  id: number;
  slug: string;
  title: string;
  body_md: string;
  body_html: string;
  tags: string[];
  draft: boolean;
  created_at: string;
  updated_at: string;
  attachments: Attachment[];
}

const { slug } = Astro.params;
const cookie = Astro.request.headers.get('cookie') ?? '';
let post: TilPost | null = null;
let backendOk = true;

if (slug) {
  try {
    // Forward the visitor's cookie so the backend can distinguish admin vs guest.
    // - Guest: drafts return 404 (kept private)
    // - Admin: drafts return the post (so the edit/preview flow works)
    //
    // Caveat: when frontend + backend are on different origins (Pages →
    // Render), the browser doesn't send the backend's auth cookie to the
    // Pages domain. SSR can't read drafts in that case — we fall back to
    // a client-side loader (TilDraftLoader) which fetches with
    // credentials:'include' directly against the backend domain.
    const res = await fetch(`${API_BASE}/api/til/${slug}`, {
      headers: cookie ? { cookie } : {},
    });
    if (res.ok) {
      post = (await res.json()) as TilPost;
    }
  } catch {
    backendOk = false;
  }
}
// Note: deliberately not redirecting when post is missing. Could be a draft
// that SSR can't see cross-origin — let the client retry with credentials.

const fmt = (s: string) =>
  new Date(s).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });

const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site ?? 'https://gokulraam.dev',
).toString();
---

<Base
  title={post ? `${post.title} — TIL` : 'TIL'}
  description={post?.title ?? 'TIL'}
  ogImage={post ? `${API_BASE}/api/og/til/${post.slug}.png` : undefined}
>
  {!backendOk && <BackendWarming client:load />}

  {
    post && (
      <article>
        <a href="/til" class="font-mono text-xs text-mist hover:text-cream">
          ← back to til
        </a>

        <PostStatusActions
          client:load
          postId={post.id}
          postTitle={post.title}
          initialDraft={post.draft}
        />

        <header class="mt-2 mb-10">
          <div class="label mb-3">// {fmt(post.created_at)}</div>

          <EditableTitle client:load postId={post.id} initial={post.title} />

          <div class="mt-4">
            <EditableTags client:load postId={post.id} initial={post.tags} />
          </div>
        </header>

        <EditableBody
          client:load
          postId={post.id}
          initialMd={post.body_md}
          initialHtml={post.body_html}
        />

        <EditableAttachments client:load postId={post.id} initial={post.attachments} />

        <TilShare
          client:load
          slug={post.slug}
          apiBase={API_BASE}
          pageUrl={canonicalUrl}
        />
      </article>
    )
  }

  {/* SSR couldn't load the post — try client-side with credentials.
      Handles the cross-origin draft case (Pages → Render) plus straightforward
      "post deleted" / "wrong URL" gracefully. */}
  {!post && backendOk && slug && (
    <TilDraftLoader client:only="react" slug={slug} />
  )}
</Base>
