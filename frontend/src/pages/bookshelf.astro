---
export const prerender = false;

import Base from '@/layouts/Base.astro';
import Card from '@/components/Card.astro';
import EditableField from '@/components/admin/EditableField';

const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8000';

interface BookRow {
  id: number;
  slug: string;
  title: string;
  author: string;
  status: string;
  year: string;
  link: string;
  cover_url: string;
  note: string;
  order: number;
}

let booksList: BookRow[] = [];
let backendOk = true;
try {
  const res = await fetch(`${API_BASE}/api/books`);
  if (res.ok) booksList = await res.json();
  else backendOk = false;
} catch {
  backendOk = false;
}

const sections: { key: string; label: string; kicker: string }[] = [
  { key: 'reading',  label: 'currently reading', kicker: 'on the bedside table' },
  { key: 'finished', label: 'finished',          kicker: 'kept on the shelf' },
  { key: 'want',     label: 'want to read',      kicker: 'next in the queue' },
];
---

<Base title="Bookshelf — Gokul Raam" description="Books I'm reading, finished, and want to read.">
  <header class="mb-12">
    <div class="label mb-4">// bookshelf</div>
    <h1 class="display text-5xl md:text-6xl">
      Things I'm<br /><span class="italic text-ember">reading.</span>
    </h1>
    <p class="mt-6 max-w-xl text-mist">
      Books currently open, books finished, books waiting their turn.
    </p>
  </header>

  {!backendOk && (
    <div class="card border-rose/30 bg-rose/5 mb-8">
      <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-rose mb-2">// backend offline</p>
      <p class="text-sm text-parchment">The API at <code class="font-mono">{API_BASE}</code> is unreachable.</p>
    </div>
  )}

  {sections.map((sec) => {
    const items = booksList.filter((b) => b.status === sec.key);
    if (items.length === 0) return null;
    return (
      <section class="mb-12">
        <div class="flex items-baseline gap-4 mb-5">
          <p class="label">// {sec.label} · {items.length}</p>
          <p class="font-display italic text-mist text-sm">{sec.kicker}</p>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {items.map((b) => (
            <Card>
              <article class="flex gap-4">
                {b.cover_url ? (
                  <img src={b.cover_url} alt={b.title} class="book-cover" loading="lazy" />
                ) : (
                  <div class="book-cover book-cover--empty">
                    <span class="font-mono text-[9.5px] uppercase tracking-[0.18em] text-ghost">
                      no cover
                    </span>
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <h2 class="font-display text-xl leading-tight">
                    <EditableField
                      client:load
                      endpoint={`/api/books/${b.id}`}
                      field="title"
                      initial={b.title}
                      className="font-display"
                    />
                  </h2>
                  <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.14em] text-mist">
                    <EditableField client:load endpoint={`/api/books/${b.id}`} field="author" initial={b.author} className="font-mono" />
                    {b.year && (
                      <> · <EditableField client:load endpoint={`/api/books/${b.id}`} field="year" initial={b.year} className="font-mono" /></>
                    )}
                  </p>
                  {b.note && (
                    <p class="mt-3 text-sm leading-relaxed text-cream/85">
                      <EditableField client:load endpoint={`/api/books/${b.id}`} field="note" initial={b.note} format="longtext" />
                    </p>
                  )}
                  <div class="mt-3 flex flex-wrap items-center gap-2">
                    <span class="chip-accent">
                      <EditableField client:load endpoint={`/api/books/${b.id}`} field="status" initial={b.status} className="font-mono" />
                    </span>
                    {b.link && (
                      <a href={b.link} target="_blank" rel="noopener" class="chip-accent">read more ↗</a>
                    )}
                  </div>
                </div>
              </article>
            </Card>
          ))}
        </div>
      </section>
    );
  })}
</Base>
