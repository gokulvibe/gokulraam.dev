---
import '@/styles/globals.css';
import AdminBar from '@/components/admin/AdminBar';
import CmdK from '@/components/CmdK';
import EasterEggs from '@/components/EasterEggs';
import ThemeToggle from '@/components/ThemeToggle';
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'Gokul Raam — Backend Engineer',
  description = 'Backend engineer building fast, maintainable APIs. Python · FastAPI · PostgreSQL · Redis.',
  ogImage,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://gokulraam.dev').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Gokul Raam — Today I Learnt" href="/til/rss.xml" />
    <meta name="theme-color" content="#0b0b0f" />

    <!-- Apply persisted theme BEFORE first paint so there's no flash. -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved === 'light' || saved === 'dark' ? saved : 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,30..100;1,9..144,300..700,30..100&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImage} />
      </>
    )}
  </head>
  <body class="font-body">
    <!-- Atmospheric background layers -->
    <div class="atmosphere"></div>
    <div class="grid-veil"></div>
    <div class="grain"></div>

    <div class="mx-auto max-w-6xl px-6 py-7 md:px-10 md:py-10">
      <header class="mb-14 flex items-center justify-between">
        <a href="/" class="group flex items-baseline gap-2 font-mono text-[12.5px] tracking-[0.18em] uppercase">
          <span class="text-gold">◆</span>
          <span class="text-cream">gokul</span>
          <span class="text-mist">/</span>
          <span class="text-mist group-hover:text-cream transition-colors">raam</span>
        </a>
        <nav class="hidden gap-7 font-mono text-[11.5px] uppercase tracking-[0.18em] text-mist md:flex">
          <a href="/work" class="hover:text-cream transition-colors">work</a>
          <a href="/projects" class="hover:text-cream transition-colors">projects</a>
          <a href="/til" class="hover:text-cream transition-colors">til</a>
          <a href="/now" class="hover:text-cream transition-colors">now</a>
          <a href="/badminton" class="hover:text-cream transition-colors">badminton</a>
          <a href="/uses" class="hover:text-cream transition-colors">uses</a>
          <a
            href="/guestbook"
            class="text-cream hover:text-gold transition-colors inline-flex items-center gap-1.5"
            title="Sign the guestbook"
          >
            <span aria-hidden class="text-gold">✎</span> guestbook
          </a>
          <a href="/resume.pdf" class="text-ember hover:opacity-80 transition-opacity">cv ↗</a>
        </nav>
      </header>

      <slot />

      <footer class="mt-32 border-t border-rule pt-8">
        <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center">
          <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.16em] text-ghost">
            <span class="text-gold">◇</span>
            <span>folio · mmxxvi · coimbatore</span>
          </div>
          <div class="flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-[11px] uppercase tracking-[0.16em] text-mist">
            <button
              type="button"
              id="footer-cmdk"
              class="hover:text-cream transition-colors inline-flex items-center gap-1.5 uppercase tracking-[0.16em]"
              title="Open site-wide search"
            >
              <kbd class="rounded border border-rule px-1 py-0.5 text-[9.5px] leading-none text-cream">⌘K</kbd>
              search
            </button>
            <a href="/til/rss.xml" class="hover:text-cream" title="Subscribe via RSS">rss</a>
            <a href="/logbook" class="hover:text-cream" title="Short-form observations">logbook</a>
            <a href="/guestbook" class="hover:text-cream" title="Sign the guestbook">guestbook</a>
            <span class="hidden h-3 w-px bg-rule md:inline-block"></span>
            <a href="https://github.com/gokulvibe" class="hover:text-cream">github</a>
            <a href="https://linkedin.com/in/gokulraam" class="hover:text-cream">linkedin</a>
            <a href="mailto:dev.gokulraam@gmail.com" class="hover:text-cream">email</a>
          </div>
        </div>
      </footer>

      <!-- Footer ⌘K button → fires the same chord CmdK listens for -->
      <script is:inline>
        document.getElementById('footer-cmdk')?.addEventListener('click', () => {
          window.dispatchEvent(new KeyboardEvent('keydown', {
            key: 'k',
            metaKey: true,
            ctrlKey: true,
            bubbles: true,
          }));
        });
      </script>
    </div>

    <!-- Page-view tracking. Fires once on initial load. Excludes /admin/*.
         Uses fetch+keepalive so the request survives if the user navigates
         away immediately. Cookies travel along so admin self-views are
         flagged server-side (filtered out of dashboard counts). -->
    <script is:inline define:vars={{ apiBase: import.meta.env.PUBLIC_API_BASE ?? '' }}>
      (function () {
        try {
          var path = window.location.pathname;
          if (path.startsWith('/admin')) return;
          var url = (apiBase || '') + '/api/stats/track';
          fetch(url, {
            method: 'POST',
            body: JSON.stringify({ path: path, referrer: document.referrer || '' }),
            headers: { 'Content-Type': 'application/json' },
            keepalive: true,
            credentials: 'include',
          }).catch(function () {});
        } catch (e) {}
      })();
    </script>

    <!-- Theme switcher — top-right of every page, works for everyone -->
    <ThemeToggle client:load />

    <!-- cmd+k / ctrl+k search modal — works for everyone -->
    <CmdK client:load />

    <!-- Floating admin bar — renders only when authenticated -->
    <AdminBar client:load />

    <!-- Easter eggs — shutter chord + 'knock' keyword. Renders nothing visible. -->
    <EasterEggs client:load />

    <style is:global>
      /* Easter-egg toast (bottom-right corner, gold left rule) */
      .egg-toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        background: rgba(8, 8, 12, 0.96);
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-left: 2px solid #d5b275;
        color: #f5efe3;
        padding: 14px 18px;
        display: flex;
        gap: 14px;
        align-items: flex-start;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 12px;
        max-width: 320px;
        border-radius: 2px;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.5);
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.32s ease, transform 0.32s ease;
      }
      .egg-toast.is-open {
        opacity: 1;
        transform: translateY(0);
      }
      .egg-toast__glyph {
        font-size: 22px;
        line-height: 1;
        flex-shrink: 0;
      }
      .egg-toast__body {
        flex: 1;
      }
      .egg-toast__title {
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 10.5px;
        color: rgba(245, 239, 227, 0.78);
        margin-bottom: 6px;
      }
      .egg-toast__link {
        color: #d5b275;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 11px;
        text-decoration: none;
        font-weight: 500;
      }
      .egg-toast__link:hover { color: #fff; }
      .egg-toast__x {
        position: absolute;
        top: 4px;
        right: 6px;
        background: transparent;
        border: none;
        color: rgba(245, 239, 227, 0.4);
        font-size: 16px;
        line-height: 1;
        cursor: pointer;
        padding: 4px 6px;
      }
      .egg-toast__x:hover { color: #fff; }

      [data-theme='light'] .egg-toast {
        background: rgba(252, 248, 240, 0.98);
        border-color: rgba(0, 0, 0, 0.16);
        color: #1c1a14;
      }
      [data-theme='light'] .egg-toast__title { color: rgba(28, 26, 20, 0.65); }
      [data-theme='light'] .egg-toast__x { color: rgba(28, 26, 20, 0.4); }
      [data-theme='light'] .egg-toast__x:hover { color: #1c1a14; }

      /* Camera flash overlay */
      .egg-flash {
        position: fixed;
        inset: 0;
        background: #fff;
        opacity: 0;
        pointer-events: none;
        z-index: 998;
      }
      .egg-flash.is-on {
        animation: egg-flash-anim 0.55s ease-out forwards;
      }
      @keyframes egg-flash-anim {
        0%   { opacity: 0;    }
        18%  { opacity: 0.85; }
        100% { opacity: 0;    }
      }

      @media (prefers-reduced-motion: reduce) {
        .egg-flash.is-on { animation-duration: 0.2s; }
        .egg-toast { transition: none; }
      }
    </style>

    <!-- Card expander: vanilla, no framework, ~80 lines -->
    <script is:inline>
      (() => {
        let activeClone = null;
        let activeOriginal = null;
        let isAnimating = false;

        const backdrop = (() => {
          const el = document.createElement('div');
          el.className = 'card-backdrop';
          el.setAttribute('aria-hidden', 'true');
          document.body.appendChild(el);
          return el;
        })();

        function bindTilt(card) {
          if (card.__tilt) return;
          card.__tilt = true;
          const onMove = (e) => {
            const r = card.getBoundingClientRect();
            const x = (e.clientX - r.left) / r.width;
            const y = (e.clientY - r.top) / r.height;
            card.style.setProperty('--mx', `${x * 100}%`);
            card.style.setProperty('--my', `${y * 100}%`);
            const tx = (y - 0.5) * 5;
            const ty = (0.5 - x) * 5;
            card.style.transform = `perspective(900px) rotateX(${tx}deg) rotateY(${ty}deg) translateZ(0)`;
          };
          const onLeave = () => {
            card.style.transform = '';
          };
          card.addEventListener('mousemove', onMove);
          card.addEventListener('mouseleave', onLeave);
        }

        function expand(card) {
          if (isAnimating || activeClone) return;
          isAnimating = true;

          const rect = card.getBoundingClientRect();
          const clone = card.cloneNode(true);
          clone.classList.add('card-clone');
          clone.removeAttribute('data-expandable');
          clone.style.transform = '';

          // Initial position == original
          Object.assign(clone.style, {
            position: 'fixed',
            top: rect.top + 'px',
            left: rect.left + 'px',
            width: rect.width + 'px',
            height: rect.height + 'px',
            transition: 'none',
            margin: '0',
          });

          // Close button
          const close = document.createElement('button');
          close.className = 'card-close';
          close.setAttribute('aria-label', 'Close card');
          close.innerHTML = '×';
          close.addEventListener('click', (e) => {
            e.stopPropagation();
            collapse();
          });
          clone.appendChild(close);

          document.body.appendChild(clone);
          card.style.visibility = 'hidden';

          backdrop.classList.add('is-active');
          document.body.style.overflow = 'hidden';

          // Force reflow before transition
          void clone.offsetHeight;

          // Target geometry: centered, capped
          const targetW = Math.min(window.innerWidth * 0.92, 1080);
          const targetH = Math.min(window.innerHeight * 0.92, 880);
          const targetL = (window.innerWidth - targetW) / 2;
          const targetT = (window.innerHeight - targetH) / 2;

          requestAnimationFrame(() => {
            clone.style.transition = '';
            clone.classList.add('is-open');
            clone.style.top = targetT + 'px';
            clone.style.left = targetL + 'px';
            clone.style.width = targetW + 'px';
            clone.style.height = targetH + 'px';
          });

          activeClone = clone;
          activeOriginal = card;
          setTimeout(() => { isAnimating = false; }, 650);
        }

        function collapse() {
          if (!activeClone || !activeOriginal || isAnimating) return;
          isAnimating = true;

          const clone = activeClone;
          const original = activeOriginal;
          const rect = original.getBoundingClientRect();

          clone.classList.remove('is-open');
          clone.style.top = rect.top + 'px';
          clone.style.left = rect.left + 'px';
          clone.style.width = rect.width + 'px';
          clone.style.height = rect.height + 'px';

          backdrop.classList.remove('is-active');

          const done = () => {
            clone.remove();
            original.style.visibility = '';
            document.body.style.overflow = '';
            activeClone = null;
            activeOriginal = null;
            isAnimating = false;
          };

          clone.addEventListener('transitionend', done, { once: true });
          setTimeout(done, 800); // safety net
        }

        // Click delegation
        document.addEventListener('click', (e) => {
          const card = e.target.closest('[data-expandable]:not(.card-clone)');
          if (card) {
            // Don't expand if clicking a real link/button inside the card
            const inner = e.target.closest('a, button');
            if (inner && !inner.classList.contains('card-close')) return;
            e.preventDefault();
            expand(card);
            return;
          }
          if (e.target === backdrop) collapse();
        });

        // Keyboard
        document.addEventListener('keydown', (e) => {
          if (!activeClone) return;
          if (e.key === 'Escape') collapse();
        });

        // Initial bind
        function bindAll() {
          document.querySelectorAll('[data-expandable]').forEach((card) => {
            bindTilt(card);
            card.setAttribute('role', 'button');
            card.setAttribute('tabindex', '0');
            card.addEventListener('keydown', (e) => {
              if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                expand(card);
              }
            });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', bindAll);
        } else {
          bindAll();
        }
      })();
    </script>
  </body>
</html>
