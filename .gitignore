# ─── Node / Astro ──────────────────────────────
frontend/node_modules
frontend/dist
frontend/.astro
frontend/.wrangler
frontend/.vercel

# ─── Python ─────────────────────────────────────
backend/.venv
backend/__pycache__
backend/**/__pycache__
backend/*.pyc
backend/**/*.pyc
backend/.pytest_cache
backend/htmlcov
backend/.coverage

# ─── Local data (must never be committed) ──────
backend/data/*.db
backend/data/*.db-journal
backend/data/*.db-wal
backend/data/*.db-shm
backend/data/uploads/*
!backend/data/uploads/.gitkeep

# ─── Secrets / env ─────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ─── OS / editors ──────────────────────────────
.DS_Store
*.swp
*.swo
*~
.idea
.vscode

# ─── Fonts (drop your TTFs in but don't commit licensed ones) ──
backend/app/fonts/*.ttf
backend/app/fonts/*.otf
backend/app/fonts/*.woff*

# ─── Audio (drop your ambient track in but don't commit big files) ──
frontend/public/audio/*.mp3
frontend/public/audio/*.m4a
frontend/public/audio/*.ogg

# ─── Misc ──────────────────────────────────────
*.log
tmp/
